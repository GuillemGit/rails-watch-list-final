<div class="container">
  <div class="row my-5 w-50 mx-auto">
    <div class="col">
      <h1>Add a new movie to <%= @list.name %> list</h1>
      <%= simple_form_for [@list, @bookmark] do |f| %>
        <%= f.input :comment %>
        <%= f.association :movie %>
        <%= f.submit "Add movie to the list", class: "btn btn-primary"%>
      <% end %>
    </div>
  </div>
</div>
