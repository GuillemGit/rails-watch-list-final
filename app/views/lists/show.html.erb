<div class="banner" style="background-image: linear-gradient(rgba(0,0,0,0.4),rgba(0,0,0,0.4)), url(https://raw.githubusercontent.com/lewagon/fullstack-images/master/uikit/background.png);">
  <div class="container">
    <h1 class="my-2"><%= @list.name %> list</h1>
    <%= link_to "+ Ajouter un film", new_list_bookmark_path(@list), class: "btn btn-primary text-decoration-none" %>
  </div>
</div>

<div class="container">
  <div class="row my-3">
    <% @bookmarks.each do |bookmark| %>
      <% movie = bookmark.movie %>
      <div class="col-12 col-sm-6 mb-4" data-aos="zoom-in">
        <%= render "movie", locals: { bookmark: bookmark, movie: movie } %>
      </div>
    <% end %>
  </div>
</div>
